{
    "compileOnSave": true,
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "lib": ["ESNext", "DOM"],
        "sourceMap": true,
        "allowJs": true,
        "removeComments": true,
        "strict": true,
        "noImplicitReturns": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "outDir": "dist",
        "rootDir": "src",
        "isolatedModules": true
    },
    "include": ["src"],
    "exclude": ["node_modules"]
}
