{
    "compileOnSave": true,
    "compilerOptions": {
        "types": ["jquery", "lodash"], // incluindo os types de jQuery e Lodash
        "target": "ESNext",
        "module": "ESNext",
        "lib": ["ESNext", "DOM"],
        "sourceMap": true,
        "allowJs": true,
        "removeComments": true,
        "strict": true,
        "noImplicitReturns": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "outDir": "dist",
        "rootDir": "src",
        "isolatedModules": true
        // "esModuleInterop": true,
    },
    "include": ["src"],
    "exclude": ["node_modules"]
}
